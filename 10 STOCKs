// Global Top 10 Live Widget - 장 시작/마감 업데이트 및 순위 변동 표기 패치
const version = "11.0-GlobalTop10Live"

// [1] 데이터 저장소 설정 🛠️
const fm = FileManager.iCloud()
const dir = fm.documentsDirectory()
const filePath = fm.joinPath(dir, "GlobalTop10LiveData.json")

async function loadData() {
  let data = null
  if (fm.fileExists(filePath)) {
    if (!fm.isFileDownloaded(filePath)) await fm.downloadFileFromiCloud(filePath)
    try { data = JSON.parse(fm.readString(filePath)) } catch(e) {}
  }
  
  if (!data || !data.shares) {
    data = {
      shares: {}, 
      settings: {
        titleFont: "AppleSDGothicNeo-Bold", titleSize: 13,
        itemFont: "AppleSDGothicNeo-Regular", itemSize: 11,
        totalLabel: "💰 내 자산 총액:",
        itemSpacing: 2
      },
      prevRanks: {},      // 이전 순위 기록용
      currentRanks: {},   // 현재 순위 기록용
      lastUpdatePeriod: "" // OPEN or CLOSE 상태 기록
    }
  }
  return data
}

function saveData(data) {
  fm.writeString(filePath, JSON.stringify(data, null, 2))
}

